{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      ".github/**",
      "README.md",
      "*firebase-adminsdk*.json"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png)",
        "headers": [ { "key": "Cache-Control", "value": "public, max-age=3600" } ]
      }
    ]
  }
}
